# Database
DATABASE_URL=postgresql://postgres:postgres_password@localhost:5432/omniscribe_db

# Kafka / Redpanda
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# S3 / MinIO
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=omniscribe-chunks
